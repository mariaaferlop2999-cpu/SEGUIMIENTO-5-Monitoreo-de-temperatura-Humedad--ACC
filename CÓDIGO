        temp = sensor_dht.temperature() # Guardamos temperatura
        hum = sensor_dht.humidity() # Guardamos humedad
    except:
        temp = 0  # Si hay error, mostramos 0
        hum = 0

    #  LEER SENSOR DE MOVIMIENTO
    try:
        ax = leer(0x3B)/16384  # Leemos movimiento en eje X y ajustamos la escala
        ay = leer(0x3D)/16384  # Leemos movimiento en eje Y
        az = leer(0x3F)/16384  # Leemos movimiento en eje Z
        mov = math.sqrt(ax*ax + ay*ay + az*az) # Calculamos la intensidad total del movimiento
    except:
        mov = 0  # Si hay error, mostramos 0

    alerta = "NORMAL"  # Estado inicial
