server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)  # Creamos el servidor web
server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1) # Permite reutilizar la IP si se reinicia
server.settimeout(2) # Tiempo máximo de espera de conexión
server.bind(("", 80))# Lo conectamos al puerto 80 (estándar web)
server.listen(5) # Permite hasta 5 conexiones al mismo tiempo

print("Servidor listo") # Aviso de que ya se puede entrar a la página
ultimo_alerta = "" # Guardamos la última alerta para no enviarla varias veces seguidas

while True:  # Bucle infinito
    if not wifi.isconnected(): # Si se fue el internet
        conectar_wifi() #intentamos reconectar
