# Configuramos el protocolo I2C, que sirve para comunicarse con el sensor de movimiento MPU6050
i2c = I2C(0, scl=Pin(18), sda=Pin(19), freq=100000)
MPU = 0x68  # Dirección única del sensor MPU6050 en el bus de datos

def leer(reg): # Función para leer valores del sensor de movimiento
    h = i2c.readfrom_mem(MPU, reg, 1)[0] # Leemos la parte alta del número
    l = i2c.readfrom_mem(MPU, reg+1, 1)[0] # Leemos la parte baja del número
    v = (h << 8) | l # Unimos ambas partes para formar el valor completo
    if v > 32768: # Si el valor es negativo
        v -= 65536 # lo convertimos al formato positivo
    return v                               

buzzer = PWM(Pin(26)) # Conectamos el zumbador al pin 26, usando señal PWM para controlar el sonido
buzzer.duty(0) # Iniciamos con volumen en 0, es decir, apagado
boton_panico = Pin(14, Pin.IN, Pin.PULL_UP) # Definimos el pin 14 como entrada para el botón PANICO
panico = False # Variable que nos dice si se activó la alarma

def panic(pin): # Función que se ejecuta cuando presionamos el botón
    global panico # Usamos la variable de arriba en esta función
    panico = True # Marcamos que se activó la emergencia

boton_panico.irq(trigger=Pin.IRQ_FALLING, handler=panic) 
#  Esta línea hace que el programa detecte al instante cuando presionas el botón, sin tener que estar revisando todo el tiempo
TEMP_ALTA = 24  # Si la temperatura pasa de 24°C → ALTA
TEMP_BAJA = 18  # Si baja de 18°C → BAJA

HUM_ALTA = 60 # Si la humedad pasa del 60% → ALTA
HUM_BAJA = 40 # Si baja del 40% → BAJA

MOVIMIENTO = 1.1 # Valor mínimo para detectar que hay movimiento
MOV_BRUSCO = 1.6 # Valor para detectar un movimiento fuerte o peligroso
def buzzer_off():# Función para apagar el zumbador
    buzzer.duty(0)

def alarma(tipo): # Función que reproduce un sonido distinto según la situación
    if tipo == "PANICO":# Sonido para emergencia
        for _ in range(5):
            buzzer.freq(2500) # Tono agudo
            buzzer.duty(700)  # Volumen alto
            time.sleep(0.15)
            buzzer_off()
            time.sleep(0.15)

    elif tipo == "MOV_BRUSCO":# Sonido para movimiento fuerte
        buzzer.freq(1800)
        buzzer.duty(600)
        time.sleep(0.4)
        buzzer_off()

    elif tipo == "TEMP_ALTA":# Sonido para temperatura alta
        buzzer.freq(1200)
        buzzer.duty(500)
        time.sleep(0.6)
        buzzer_off()

    elif tipo == "TEMP_BAJA":# Sonido para temperatura baja
        buzzer.freq(800)
        buzzer.duty(500)
        time.sleep(0.6)
        buzzer_off()

    elif tipo == "HUM_ALTA": # Sonido para humedad alta
        buzzer.freq(1400)
        buzzer.duty(500)
        time.sleep(0.6)
        buzzer_off()

    elif tipo == "HUM_BAJA":# Sonido para humedad baja
        buzzer.freq(900)
        buzzer.duty(500)
        time.sleep(0.6)
        buzzer_off()
